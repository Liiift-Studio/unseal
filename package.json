{
	"name": "unseal",
	"version": "0.1.0",
	"description": "Detect and remove fake PDF redactions. Works on PDFs from any tool.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"unseal": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build && npm run typecheck"
	},
	"keywords": [
		"pdf",
		"redaction",
		"audit",
		"forensic",
		"security",
		"unredact",
		"unseal",
		"foia",
		"hipaa",
		"ediscovery"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/unseal"
	},
	"homepage": "https://unseal.dev",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"commander": "^12.0.0",
		"pdf-lib": "^1.17.1",
		"pdfjs-dist": "^4.0.379"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.4.0",
		"vitest": "^1.6.0"
	}
}
